<Window x:Class="Poe2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Poe2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>
        
        <Style TargetType="Button">
            
            <Setter Property="Background" Value="#7AA2F7"/>
            <Setter Property="Foreground" Value="#1A1B26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                
                <Setter.Value>
                    
                    <ControlTemplate TargetType="Button">
                        
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        
                    </ControlTemplate>
                    
                </Setter.Value>
                
            </Setter>
            
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A9B1D6"/>
                </Trigger>
            </Style.Triggers>
            
        </Style>
        
    </Window.Resources>

    <Grid>

        <Grid 
            x:Name="WelcomeGrid" 
            Visibility="Visible"
            >
            
            <StackPanel 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                >

                <Image 
                    Source="/Logo.png" 
                    Height="100" 
                    Margin="0,0,0,15" 
                    Stretch="Uniform"
                    />

                <TextBlock 
                    FontFamily="Consolas" 
                    Foreground="#9ECE6A" 
                    FontSize="14" 
                    HorizontalAlignment="Center" 
                    TextAlignment="Center" 
                    Margin="0,0,0,25" 
                    LineHeight="16"
                    >
                    
                    <Run Text="  /\  /\"/><LineBreak/>
                    <Run Text=" /  \/  \"/><LineBreak/>
                    <Run Text="/ /\/ /\ \"/><LineBreak/>
                    <Run Text="\ \/ /\/ /"/><LineBreak/>
                    <Run Text=" \ \/\ \/"/><LineBreak/>
                    <Run Text=" /\ \/\ \"/><LineBreak/>
                    <Run Text="/ /\/ /\ \"/><LineBreak/>
                    <Run Text="/ / / /\ \ \"/><LineBreak/>
                    <Run Text="/ / / /\ \ \ \"/><LineBreak/>
                    <Run Text="/_/_/_/  \_\_\_\"/>
                    
                </TextBlock>

                <TextBlock 
                    Text="Cybersecurity Awareness Bot" 
                    Foreground="#C0CAF5" 
                    FontSize="28" 
                    FontWeight="Bold" 
                    Margin="10" 
                    HorizontalAlignment="Center"
                    />
                
                <TextBlock 
                    Text="Your interactive guide to safe browsing and digital safety habits." 
                    Foreground="#565F89" 
                    FontSize="14" 
                    Margin="0,0,0,20" 
                    HorizontalAlignment="Center"
                    />
                
                <Button 
                    Content="Start Learning" 
                    Width="180" 
                    Height="42" 
                    FontSize="15" 
                    Click="Start_Click"
                    />
                
            </StackPanel>
            
        </Grid>

        <Grid 
            x:Name="NameGrid" 
            Visibility="Collapsed"
            >
            
            <StackPanel
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center"
                      >
                
                <TextBlock 
                    Text="What is your name?" 
                    Foreground="#C0CAF5" 
                    FontSize="20" 
                    Margin="10" 
                    HorizontalAlignment="Center"
                    />
                
                <Border 
                    CornerRadius="6" 
                    Background="#24283B" 
                    Padding="5" 
                    Margin="0,10,0,5"
                    >
                    
                    <TextBox 
                        x:Name="NameTextBox" 
                        Width="280" 
                        Height="35" 
                        FontSize="16" 
                        Background="Transparent" 
                        Foreground="#C0CAF5" 
                        BorderThickness="0" 
                        VerticalContentAlignment="Center" 
                        HorizontalAlignment="Center"
                        />
                    
                </Border>
                
                <TextBlock 
                    x:Name="ErrorText" 
                    Foreground="#F7768E" 
                    Margin="0,5,0,15" 
                    TextAlignment="Center" 
                    FontSize="13" 
                    FontWeight="SemiBold"
                    />
                
                <Button 
                    Content="Submit Name" 
                    Width="150" 
                    Height="40" 
                    FontSize="14" 
                    Click="Submit_Click"
                    />
                
            </StackPanel>
            
        </Grid>

        <Grid 
            x:Name="ChatGrid" 
            Visibility="Collapsed" 
            Margin="25"
            >
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock 
                Text="ShieldGuard Chat Assistant" 
                Grid.Row="0" 
                Foreground="#7AA2F7" 
                FontSize="20" 
                FontWeight="Bold" 
                Margin="5,0,0,12"
                />

            <Border 
                Grid.Row="1" 
                Background="#24283B" 
                CornerRadius="8" 
                Padding="15"
                >
                
                <Grid>
                    
                    <ScrollViewer 
                        x:Name="ChatScroller" 
                        VerticalScrollBarVisibility="Auto"
                        >
                        
                        <RichTextBox 
                            x:Name="ChatListBox" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Foreground="#C0CAF5" 
                            FontSize="15" 
                            IsReadOnly="True" 
                            Block.LineHeight="6"
                            />
                        
                    </ScrollViewer>
                    
                </Grid>
                
            </Border>

            <Grid 
                Grid.Row="2" 
                Margin="0,15,0,0"
                >
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border 
                    Background="#24283B" 
                    CornerRadius="6" 
                    Margin="0,0,12,0" 
                    Padding="12,0"
                    >
                    
                    <TextBox 
                        x:Name="MessageBox" 
                        Background="Transparent" 
                        Foreground="#C0CAF5" 
                        BorderThickness="0" 
                        FontSize="15" 
                        VerticalAlignment="Center" 
                        Height="45" 
                        KeyDown="MessageBox_KeyDown"
                        />
                    
                </Border>
                
                <Button 
                    Grid.Column="1" 
                    Content="Send Message" 
                    Width="130" 
                    Height="45" 
                    FontSize="14" 
                    Click="Send_Click"
                    />
                
            </Grid>
            
        </Grid>

    </Grid>
    
</Window>
